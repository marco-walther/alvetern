---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';

const partners = [
  {
    name: 'Lunatone',
    url: 'https://www.lunatone.com/en/',
    logo: '/partners/lunatone.png',
    blurb: 'DALI lighting control components and systems.',
  },
  {
    name: 'Elkosun',
    url: 'https://www.elkosun.com/',
    logo: '/partners/elkosun.png',
    blurb: 'Electronic components for professional lighting.',
  },
];

const services = [
  {
    title: "Manufacturer's representative",
    body: 'We represent European lighting manufacturers across North America, providing local sales, technical support, and a presence close to the customer.',
  },
  {
    title: 'Europe → North America',
    body: 'Supporting European companies as they enter and grow in the North American market, from first contact to established distribution.',
  },
  {
    title: 'North America → Europe',
    body: 'Helping US companies export their products to European markets, navigating standards, partners, and logistics.',
  },
];

const steps: {
  title: string;
  body: string;
  link?: { text: string; href: string };
}[] = [
  {
    title: 'Tell us your need',
    body: 'Share the product you’re looking for or the lighting solution you need: ',
    link: { text: 'get in touch', href: '#contact' },
  },
  {
    title: 'We source & represent',
    body: 'We connect you with the right European manufacturer or North American partner from our network.',
  },
  {
    title: 'Compliance & logistics',
    body: 'We help navigate UL/CE standards, customs, and trans-Atlantic shipping so nothing gets stuck.',
  },
  {
    title: 'Delivered & supported',
    body: 'Your components arrive, backed by ongoing local support on the right side of the ocean.',
  },
];
---

<Layout>
  <Header />

  <main>
    <!-- Hero -->
    <section class="hero">
      <img
        class="hero-img hero-switzerland"
        src="/switzerland.jpg"
        alt=""
        aria-hidden="true"
      />
      <img
        class="hero-img hero-atlanta"
        src="/atlanta.jpg"
        alt=""
        aria-hidden="true"
      />
      <div class="hero-overlay" aria-hidden="true"></div>
      <div class="wrap hero-inner">
        <p class="eyebrow">Lighting components and more</p>
        <h1>European lighting, represented in&nbsp;North&nbsp;America.</h1>
        <p class="lede">
          Alvetern Inc. is a trading company and European manufacturer
          representative for the North American market, and a two-way bridge
          for companies crossing the Atlantic in either direction.
        </p>
        <div class="actions">
          <a class="btn primary" href="#contact">Contact us</a>
          <a class="btn ghost" href="#partners">Our partners</a>
        </div>
      </div>
    </section>

    <!-- What we do -->
    <section id="about" class="section">
      <div class="wrap">
        <h2 class="section-title">What we do</h2>
        <p class="section-sub">
          We connect European lighting innovators with North America, and open
          European doors for North American manufacturers.
        </p>
        <div class="cards">
          {
            services.map((s) => (
              <article class="card">
                <h3>{s.title}</h3>
                <p>{s.body}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <!-- How we work -->
    <section id="how" class="section section-soft">
      <div class="wrap">
        <h2 class="section-title">How we work</h2>
        <p class="section-sub">
          A simple path from first contact to delivered components, across the
          Atlantic, in either direction.
        </p>
        <ol class="steps">
          {
            steps.map((s, i) => (
              <li class="step">
                <span class="step-num">{i + 1}</span>
                <h3>{s.title}</h3>
                <p>
                  {s.body}
                  {s.link && (
                    <a class="step-link" href={s.link.href}>
                      {s.link.text}
                    </a>
                  )}
                </p>
              </li>
            ))
          }
        </ol>
      </div>
    </section>

    <!-- Partners -->
    <section id="partners" class="section">
      <div class="wrap">
        <h2 class="section-title">Partners we represent</h2>
        <p class="section-sub">
          Proud to represent leading European lighting manufacturers.
        </p>
        <div class="partners">
          {
            partners.map((p) => (
              <a
                class="partner"
                href={p.url}
                target="_blank"
                rel="noopener noreferrer"
              >
                <img class="partner-logo" src={p.logo} alt={p.name} />
                <span class="partner-blurb">{p.blurb}</span>
                <span class="partner-link">Visit site →</span>
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Contact -->
    <section id="contact" class="section section-soft">
      <div class="wrap">
        <h2 class="section-title">Get in touch</h2>
        <p class="section-sub">
          Tell us about your products or your market. We’ll help you find the
          way across. Send an inquiry and we’ll get back to you.
        </p>
        <div class="contact-grid">
          <form id="inquiry" class="inquiry-form">
            {/* Web3Forms: replace the access key below with your own */}
            <input
              type="hidden"
              name="access_key"
              value="0f5b27a4-698e-4d1f-8a9f-d21012fe4c15"
            />
            <input
              type="hidden"
              name="subject"
              value="New inquiry from alvetern.com"
            />
            <input
              type="checkbox"
              name="botcheck"
              class="hp"
              tabindex="-1"
              autocomplete="off"
            />

            <div class="form-fields">
              <div class="row">
                <div class="field">
                  <label for="name">Name *</label>
                  <input id="name" name="name" type="text" required />
                </div>
                <div class="field">
                  <label for="company">Company</label>
                  <input id="company" name="company" type="text" />
                </div>
              </div>
              <div class="row">
                <div class="field">
                  <label for="email">Email *</label>
                  <input id="email" name="email" type="email" required />
                </div>
                <div class="field">
                  <label for="phone">Phone</label>
                  <input id="phone" name="phone" type="tel" />
                </div>
              </div>
              <div class="field">
                <label for="message">How can we help? *</label>
                <textarea id="message" name="message" rows="5" required
                ></textarea>
              </div>
            </div>

            <address class="contact-card">
              <strong>Alvetern Inc.</strong>
              <span>Lawrenceville, GA 30043</span>
              <span class="spacer"></span>
              <a href="tel:+14047254888">+1 (404) 725-4888</a>
              <a href="mailto:guido.walther@alvetern.com"
                >guido.walther@alvetern.com</a
              >
              <img
                class="contact-photo"
                src="/headshot-guido.jpg"
                alt="Guido Walther"
                width="200"
                height="200"
              />
            </address>

            <button class="btn primary" type="submit">Send inquiry</button>
            <p class="form-status" role="status" aria-live="polite" hidden></p>
          </form>
        </div>
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <div class="wrap footer-inner">
      <span class="footer-copy">© {new Date().getFullYear()} Alvetern Inc.</span>
      <span>Lawrenceville, GA · USA</span>
    </div>
  </footer>

  <script>
    const form = document.getElementById('inquiry') as HTMLFormElement | null;
    if (form) {
      const status = form.querySelector('.form-status') as HTMLElement;
      const button = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        status.hidden = false;
        status.className = 'form-status';
        status.textContent = 'Sending…';
        button.disabled = true;
        try {
          const res = await fetch('https://api.web3forms.com/submit', {
            method: 'POST',
            headers: { Accept: 'application/json' },
            body: new FormData(form),
          });
          const data = await res.json();
          if (data.success) {
            form.reset();
            status.classList.add('ok');
            status.textContent =
              'Thanks! We received your inquiry and will be in touch shortly.';
          } else {
            throw new Error(data.message || 'Submission failed');
          }
        } catch (err) {
          status.classList.add('err');
          status.textContent =
            'Sorry, something went wrong. Please email guido.walther@alvetern.com directly.';
        } finally {
          button.disabled = false;
        }
      });
    }
  </script>
</Layout>

<style>
  /* Hero: Atlanta (left) blending into Switzerland (right) */
  .hero {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    color: #fff;
    min-height: clamp(440px, 72vh, 660px);
    display: flex;
    align-items: center;
  }
  .hero-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }
  .hero-atlanta {
    z-index: 1;
    object-position: 72% 28%;
    -webkit-mask-image: linear-gradient(to right, #000 26%, transparent 60%);
    mask-image: linear-gradient(to right, #000 26%, transparent 60%);
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    background: linear-gradient(
      100deg,
      rgba(8, 32, 12, 0.82) 0%,
      rgba(8, 32, 12, 0.5) 45%,
      rgba(8, 40, 14, 0.6) 100%
    );
  }
  .hero-inner {
    position: relative;
    z-index: 3;
    padding-block: clamp(3rem, 10vh, 6rem);
  }
  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.28em;
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--accent);
    margin: 0 0 1rem;
  }
  .hero h1 {
    font-size: clamp(2.25rem, 6vw, 4rem);
    margin: 0 0 1.25rem;
    max-width: 18ch;
  }
  .lede {
    font-size: clamp(1.05rem, 2.2vw, 1.3rem);
    color: rgba(255, 255, 255, 0.92);
    max-width: 46rem;
    margin: 0 0 2rem;
  }
  .actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .btn {
    display: inline-block;
    padding: 0.8rem 1.5rem;
    border-radius: 999px;
    font-weight: 700;
    text-decoration: none;
    transition: transform 0.12s ease, box-shadow 0.12s ease, background 0.12s ease;
  }
  .btn:hover {
    transform: translateY(-1px);
  }
  .btn.primary {
    background: var(--accent);
    color: #3a2c00;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.18);
  }
  .btn.ghost {
    border: 1.5px solid rgba(255, 255, 255, 0.6);
    color: #fff;
  }
  .btn.ghost:hover {
    background: rgba(255, 255, 255, 0.12);
  }

  /* Sections */
  .section {
    padding-block: clamp(3rem, 9vh, 6rem);
  }
  .section-soft {
    background: var(--bg-soft);
    border-block: 1px solid var(--line);
  }
  .section-title {
    font-size: clamp(1.6rem, 3.5vw, 2.4rem);
    margin: 0 0 0.5rem;
    color: var(--green-darker);
  }
  .section-sub {
    color: var(--muted);
    font-size: 1.1rem;
    margin: 0 0 2.5rem;
  }

  /* Service cards */
  .cards {
    display: grid;
    gap: 1.25rem;
    grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr));
  }
  .card {
    background: #fff;
    border: 1px solid var(--line);
    border-radius: 14px;
    padding: 1.5rem;
    box-shadow: 0 1px 2px rgba(18, 63, 23, 0.04);
  }
  .card h3 {
    margin: 0 0 0.5rem;
    font-size: 1.2rem;
    color: var(--green-dark);
  }
  .card p {
    margin: 0;
    color: var(--muted);
  }

  /* How we work: steps */
  .steps {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1.25rem;
    grid-template-columns: repeat(auto-fit, minmax(13rem, 1fr));
    counter-reset: step;
  }
  .step {
    position: relative;
    background: #fff;
    border: 1px solid var(--line);
    border-radius: 14px;
    padding: 1.5rem;
  }
  .step-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.2rem;
    height: 2.2rem;
    border-radius: 50%;
    background: var(--green);
    color: #fff;
    font-weight: 800;
    font-size: 1.05rem;
    margin-bottom: 0.9rem;
  }
  .step h3 {
    margin: 0 0 0.4rem;
    font-size: 1.1rem;
    color: var(--green-dark);
  }
  .step p {
    margin: 0;
    color: var(--muted);
    font-size: 0.97rem;
  }
  .step-link {
    color: var(--green-dark);
    font-weight: 700;
    text-decoration: none;
    white-space: nowrap;
  }
  .step-link:hover {
    text-decoration: underline;
  }

  /* Partner cards */
  .partners {
    display: grid;
    gap: 1.25rem;
    grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr));
  }
  .partner {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    background: #fff;
    border: 1px solid var(--line);
    border-radius: 14px;
    padding: 1.75rem;
    text-decoration: none;
    color: var(--ink);
    transition: transform 0.12s ease, box-shadow 0.12s ease, border-color 0.12s ease;
  }
  .partner:hover {
    transform: translateY(-2px);
    border-color: var(--green);
    box-shadow: 0 10px 28px rgba(18, 63, 23, 0.1);
  }
  .partner-logo {
    height: 3rem;
    width: auto;
    max-width: 85%;
    object-fit: contain;
    align-self: flex-start;
    margin-bottom: 0.25rem;
  }
  .partner-blurb {
    color: var(--muted);
  }
  .partner-link {
    margin-top: 0.5rem;
    font-weight: 700;
    color: var(--green);
  }

  /* Contact */
  .contact-card {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    font-style: normal;
    background: #fff;
    border: 1px solid var(--line);
    border-radius: 14px;
    padding: 1.75rem;
  }
  .contact-photo {
    width: 96px;
    height: 96px;
    object-fit: cover;
    border-radius: 18px;
    align-self: center;
    margin-top: auto;
  }
  .contact-card strong {
    font-size: 1.2rem;
    color: var(--green-darker);
  }
  .contact-card .spacer {
    height: 0.6rem;
  }
  .contact-card a {
    color: var(--green-dark);
    text-decoration: none;
    font-weight: 600;
  }
  .contact-card a:hover {
    text-decoration: underline;
  }

  /* Inquiry form */
  .inquiry-form {
    display: grid;
    grid-template-columns: 1fr;
    column-gap: 1.5rem;
    row-gap: 1rem;
    align-items: stretch;
  }
  .form-fields {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  /* On mobile the contact card sits last (after the button) */
  .contact-card {
    order: 1;
  }
  @media (min-width: 820px) {
    .inquiry-form {
      grid-template-columns: 1.6fr 1fr;
    }
    .form-fields {
      grid-column: 1;
      grid-row: 1;
    }
    .contact-card {
      grid-column: 2;
      grid-row: 1;
    }
    .inquiry-form .btn {
      grid-column: 1;
      grid-row: 2;
    }
    .form-status {
      grid-column: 1;
      grid-row: 3;
    }
  }
  .inquiry-form .row {
    display: grid;
    gap: 1rem;
    grid-template-columns: 1fr;
  }
  @media (min-width: 480px) {
    .inquiry-form .row {
      grid-template-columns: 1fr 1fr;
    }
  }
  .field {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  .field label {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--ink);
  }
  .field input,
  .field textarea {
    font: inherit;
    color: var(--ink);
    background: #fff;
    border: 1px solid var(--line);
    border-radius: 10px;
    padding: 0.65rem 0.8rem;
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }
  .field input:focus,
  .field textarea:focus {
    outline: none;
    border-color: var(--green);
    box-shadow: 0 0 0 3px rgba(47, 158, 52, 0.15);
  }
  .field textarea {
    resize: vertical;
  }
  .inquiry-form .btn {
    align-self: start;
    justify-self: start;
    cursor: pointer;
    border: none;
  }
  .hp {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    opacity: 0;
  }
  .form-status {
    margin: 0;
    font-size: 0.95rem;
    font-weight: 600;
  }
  .form-status.ok {
    color: var(--green-dark);
  }
  .form-status.err {
    color: #b3261e;
  }

  /* Footer */
  .site-footer {
    background: var(--green-darker);
    color: rgba(255, 255, 255, 0.85);
  }
  .footer-inner {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.4rem;
    padding-block: 0.7rem;
    font-size: 0.8rem;
  }
  .footer-copy {
    color: rgba(255, 255, 255, 0.7);
  }
</style>
