---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';

const partners = [
  {
    name: 'Lunatone',
    url: 'https://www.lunatone.com/en/',
    blurb: 'DALI lighting control components and systems.',
  },
  {
    name: 'Elkosun',
    url: 'https://www.elkosun.com/',
    blurb: 'Electronic components for professional lighting.',
  },
];

const services = [
  {
    title: "Manufacturer's representative",
    body: 'We represent European lighting manufacturers across North America, providing local sales, technical support, and a presence close to the customer.',
  },
  {
    title: 'Europe → North America',
    body: 'Supporting European companies as they enter and grow in the North American market — from first contact to established distribution.',
  },
  {
    title: 'North America → Europe',
    body: 'Helping US companies export their products to European markets, navigating standards, partners, and logistics.',
  },
];
---

<Layout>
  <Header />

  <main>
    <!-- Hero -->
    <section class="hero">
      <div class="wrap hero-inner">
        <p class="eyebrow">Lighting components — and more</p>
        <h1>European lighting, represented in&nbsp;North&nbsp;America.</h1>
        <p class="lede">
          Alvetern Inc. is a trading company and European manufacturer
          representative for the North American market — and a two-way bridge
          for companies crossing the Atlantic in either direction.
        </p>
        <div class="actions">
          <a class="btn primary" href="#contact">Contact us</a>
          <a class="btn ghost" href="#partners">Our partners</a>
        </div>
      </div>
    </section>

    <!-- What we do -->
    <section id="about" class="section">
      <div class="wrap">
        <h2 class="section-title">What we do</h2>
        <p class="section-sub">
          We connect European lighting innovators with North America, and open
          European doors for North American manufacturers.
        </p>
        <div class="cards">
          {
            services.map((s) => (
              <article class="card">
                <h3>{s.title}</h3>
                <p>{s.body}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Partners -->
    <section id="partners" class="section section-soft">
      <div class="wrap">
        <h2 class="section-title">Partners we represent</h2>
        <p class="section-sub">
          Proud to represent leading European lighting manufacturers.
        </p>
        <div class="partners">
          {
            partners.map((p) => (
              <a
                class="partner"
                href={p.url}
                target="_blank"
                rel="noopener noreferrer"
              >
                <span class="partner-name">{p.name}</span>
                <span class="partner-blurb">{p.blurb}</span>
                <span class="partner-link">Visit site →</span>
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Contact -->
    <section id="contact" class="section">
      <div class="wrap contact">
        <div>
          <h2 class="section-title">Contact</h2>
          <p class="section-sub">
            Tell us about your products or your market — we’ll help you find the
            way across.
          </p>
        </div>
        <address class="contact-card">
          <strong>Alvetern Inc.</strong>
          <span>PO Box 492034</span>
          <span>Lawrenceville, GA 30049</span>
          <span class="spacer"></span>
          <a href="tel:+14047254888">+1 (404) 725-4888</a>
          <a href="mailto:guido.walther@alvetern.com"
            >guido.walther@alvetern.com</a
          >
        </address>
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <div class="wrap footer-inner">
      <span>© {new Date().getFullYear()} Alvetern Inc.</span>
      <span>Lawrenceville, GA · USA</span>
    </div>
  </footer>
</Layout>

<style>
  /* Hero */
  .hero {
    background:
      radial-gradient(
        1100px 500px at 80% -20%,
        rgba(244, 194, 13, 0.18),
        transparent 60%
      ),
      linear-gradient(160deg, var(--green) 0%, var(--green-dark) 55%, var(--green-darker) 100%);
    color: #fff;
  }
  .hero-inner {
    padding-block: clamp(3.5rem, 12vh, 8rem);
  }
  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.28em;
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--accent);
    margin: 0 0 1rem;
  }
  .hero h1 {
    font-size: clamp(2.25rem, 6vw, 4rem);
    margin: 0 0 1.25rem;
    max-width: 18ch;
  }
  .lede {
    font-size: clamp(1.05rem, 2.2vw, 1.3rem);
    color: rgba(255, 255, 255, 0.92);
    max-width: 46rem;
    margin: 0 0 2rem;
  }
  .actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .btn {
    display: inline-block;
    padding: 0.8rem 1.5rem;
    border-radius: 999px;
    font-weight: 700;
    text-decoration: none;
    transition: transform 0.12s ease, box-shadow 0.12s ease, background 0.12s ease;
  }
  .btn:hover {
    transform: translateY(-1px);
  }
  .btn.primary {
    background: var(--accent);
    color: #3a2c00;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.18);
  }
  .btn.ghost {
    border: 1.5px solid rgba(255, 255, 255, 0.6);
    color: #fff;
  }
  .btn.ghost:hover {
    background: rgba(255, 255, 255, 0.12);
  }

  /* Sections */
  .section {
    padding-block: clamp(3rem, 9vh, 6rem);
  }
  .section-soft {
    background: var(--bg-soft);
    border-block: 1px solid var(--line);
  }
  .section-title {
    font-size: clamp(1.6rem, 3.5vw, 2.4rem);
    margin: 0 0 0.5rem;
    color: var(--green-darker);
  }
  .section-sub {
    color: var(--muted);
    font-size: 1.1rem;
    max-width: 48rem;
    margin: 0 0 2.5rem;
  }

  /* Service cards */
  .cards {
    display: grid;
    gap: 1.25rem;
    grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr));
  }
  .card {
    background: #fff;
    border: 1px solid var(--line);
    border-radius: 14px;
    padding: 1.5rem;
    box-shadow: 0 1px 2px rgba(18, 63, 23, 0.04);
  }
  .card h3 {
    margin: 0 0 0.5rem;
    font-size: 1.2rem;
    color: var(--green-dark);
  }
  .card p {
    margin: 0;
    color: var(--muted);
  }

  /* Partner cards */
  .partners {
    display: grid;
    gap: 1.25rem;
    grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr));
  }
  .partner {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    background: #fff;
    border: 1px solid var(--line);
    border-radius: 14px;
    padding: 1.75rem;
    text-decoration: none;
    color: var(--ink);
    transition: transform 0.12s ease, box-shadow 0.12s ease, border-color 0.12s ease;
  }
  .partner:hover {
    transform: translateY(-2px);
    border-color: var(--green);
    box-shadow: 0 10px 28px rgba(18, 63, 23, 0.1);
  }
  .partner-name {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--green-dark);
  }
  .partner-blurb {
    color: var(--muted);
  }
  .partner-link {
    margin-top: 0.5rem;
    font-weight: 700;
    color: var(--green);
  }

  /* Contact */
  .contact {
    display: grid;
    gap: 2rem;
    grid-template-columns: 1fr;
  }
  @media (min-width: 720px) {
    .contact {
      grid-template-columns: 1.2fr 1fr;
      align-items: start;
    }
  }
  .contact-card {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    font-style: normal;
    background: #fff;
    border: 1px solid var(--line);
    border-left: 4px solid var(--green);
    border-radius: 12px;
    padding: 1.5rem 1.75rem;
  }
  .contact-card strong {
    font-size: 1.15rem;
    color: var(--green-darker);
  }
  .contact-card .spacer {
    height: 0.5rem;
  }
  .contact-card a {
    color: var(--green-dark);
    text-decoration: none;
    font-weight: 600;
  }
  .contact-card a:hover {
    text-decoration: underline;
  }

  /* Footer */
  .site-footer {
    background: var(--green-darker);
    color: rgba(255, 255, 255, 0.85);
  }
  .footer-inner {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.5rem;
    padding-block: 1.5rem;
    font-size: 0.9rem;
  }
</style>
