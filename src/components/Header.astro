---
---

<header class="site-header">
  <a class="brand" href="/" aria-label="Alvetern Inc. home">
    <img class="brand-mark" src="/logo-a1.png" alt="" width="360" height="360" />
    <img
      class="brand-word"
      src="/logo-name.png"
      alt="Alvetern Inc."
      width="502"
      height="87"
    />
  </a>
  <nav aria-label="Primary">
    <a href="#about">What we do</a>
    <a href="#partners">Partners</a>
    <a href="#contact">Contact</a>
  </nav>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.7rem clamp(1rem, 5vw, 3rem);
    background: #fff;
    border-bottom: 1px solid var(--line);
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    text-decoration: none;
  }
  .brand-mark {
    height: 2.1rem;
    width: auto;
  }
  .brand-word {
    height: 1.2rem;
    width: auto;
  }
  nav {
    display: flex;
    gap: clamp(1rem, 3vw, 2rem);
    font-weight: 600;
    font-size: 0.95rem;
  }
  nav a {
    color: var(--ink);
    text-decoration: none;
    padding: 0.25rem 0;
    border-bottom: 2px solid transparent;
    transition: border-color 0.15s ease, color 0.15s ease;
  }
  nav a:hover {
    color: var(--green-dark);
    border-color: var(--green);
  }
  @media (max-width: 520px) {
    .brand-word {
      display: none;
    }
    nav {
      gap: 1rem;
      font-size: 0.85rem;
    }
  }
</style>
