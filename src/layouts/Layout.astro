---
interface Props {
  title?: string;
  description?: string;
}

import faviconPng from '../images/logo-a1.png';

const {
  title = 'Alvetern | European Lighting Components for North America',
  description = 'Alvetern Inc. is a trading company and European manufacturer representative for the North American lighting market, and a bridge for US companies exporting to Europe.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href={faviconPng.src} />
    <meta name="generator" content={Astro.generator} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --green: #2f9e34;
    --green-dark: #1d6b24;
    --green-darker: #123f17;
    --accent: #f4c20d;
    --ink: #16241a;
    --muted: #5b6b5d;
    --bg: #ffffff;
    --bg-soft: #f3f8f3;
    --line: #e2ece2;
    --maxw: 70rem;
    font-family:
      ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, Helvetica,
      Arial, sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  html,
  body {
    margin: 0;
    padding: 0;
  }

  body {
    min-height: 100dvh;
    background: var(--bg);
    color: var(--ink);
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
    line-height: 1.6;
  }

  a {
    color: var(--green-dark);
  }

  h1,
  h2,
  h3 {
    line-height: 1.15;
    letter-spacing: -0.02em;
  }

  .wrap {
    max-width: var(--maxw);
    margin: 0 auto;
    padding-inline: clamp(1rem, 5vw, 3rem);
  }
</style>
